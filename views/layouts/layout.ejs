<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Digital Locker </title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

  <!-- Custom CSS -->
  <link rel="stylesheet" href="/css/style.css" />

  <style>
    /* ===== GLOBAL ===== */
    body {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      background: #f6f8fb;
    }

    main {
      flex: 1;
    }

    /* ===== NAVBAR ===== */
    .main-navbar {
      background: linear-gradient(90deg, #6c63ff, #5f9cff);
      padding: 18px 0;
      box-shadow: 0 3px 10px rgba(0, 0, 0, 0.1);
    }

    .navbar-brand {
      font-size: 1.6rem;
      font-weight: 700;
      letter-spacing: 1px;
    }

    /* Bigger left title */
    .brand-title {
      font-size: 2rem;
      font-weight: 800;
      letter-spacing: 1px;
    }

    /* custom soft blue buttons */
    .btn-light-blue {
      background: #e7f1ff;
      color: #2b5cff;
      border: none;
    }

    .btn-light-blue:hover {
      background: #d5e7ff;
      color: #1d4ed8;
    }

    .nav-btn {
      padding: 8px 18px;
      border-radius: 8px;
      font-weight: 500;
    }

    /* ===== CONTENT ===== */
    .page-wrapper {
      padding-top: 35px;
      padding-bottom: 35px;
    }

    /* ===== FOOTER ===== */
    footer {
      background: linear-gradient(90deg, #6c63ff, #5f9cff);
      color: white;
      padding: 50px 0 25px;
      margin-top: 40px;
    }

    footer h5 {
      font-weight: 600;
      margin-bottom: 15px;
    }

    footer p,
    footer a {
      font-size: 14px;
      color: #f1f1f1;
      text-decoration: none;
    }

    footer a:hover {
      text-decoration: underline;
    }

    .footer-bottom {
      text-align: center;
      margin-top: 30px;
      font-size: 13px;
      opacity: 0.8;
    }
  </style>
</head>

<body>

  <!-- ================= NAVBAR ================= -->
<nav class="navbar navbar-expand-lg navbar-dark main-navbar py-3">
  <div class="container">

    <!-- LEFT TITLE -->
    <a class="navbar-brand brand-title" href="/">
       Digital Locker
    </a>

    <!-- RIGHT SIDE -->
    <div class="ms-auto">

      <% const isDashboard = currentPath === "/dashboard"; %>

      <% if (userId && isDashboard) { %>

        <!-- PROFILE CARD (only dashboard) -->
        <div class="d-flex flex-column align-items-center text-white">

          <img
            src="/images/avatar.jpg"
            width="55"
            height="55"
            class="rounded-circle border mb-1"
          />

          <small class="fw-semibold">
            <%= user?.name || "User" %>
          </small>

          <a href="/logout" class="btn btn-danger btn-sm mt-1">
            Logout
          </a>

        </div>

      <% } else { %>

        <!-- LOGIN + REGISTER everywhere else -->
        <a href="/login" class="btn btn-light-blue nav-btn me-2">Login</a>
        <a href="/register" class="btn btn-light-blue nav-btn">Register</a>

      <% } %>

    </div>
  </div>
</nav>


  <!-- ================= PAGE CONTENT ================= -->
  <main class="page-wrapper">
    <div class="container">
      <%- body %>
    </div>
  </main>


  <!-- ================= FOOTER ================= -->
  <footer>
    <div class="container">
      <div class="row">

        <div class="col-md-4 mb-4">
          <h5>🔐 Digital Locker</h5>
          <p>
            Securely upload, store and manage your personal files safely in one place.
            Fast, private and reliable cloud storage.
          </p>
        </div>

        <div class="col-md-4 mb-4">
          <h5>Quick Links</h5>
          <p><a href="/">Home</a></p>
          <p><a href="/dashboard">Dashboard</a></p>
          <p><a href="/login">Login</a></p>
        </div>

        <div class="col-md-4 mb-4">
          <h5>Contact</h5>
          <p>Email: support@digitallocker.com</p>
          <p>Made with ❤️ using Node.js & MongoDB</p>
        </div>

      </div>

      <div class="footer-bottom">
        © 2026 Digital Locker. All rights reserved.
      </div>
    </div>
  </footer>


  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>